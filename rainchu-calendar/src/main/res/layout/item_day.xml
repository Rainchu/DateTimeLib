<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:padding="4dp">

        <androidx.cardview.widget.CardView

            android:id="@+id/cardDay"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvDay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="15"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </androidx.cardview.widget.CardView>

        <!-- Holiday/Event Dot -->
        <View
            android:id="@+id/viewDot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_dot"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/cardDay"
            app:layout_constraintStart_toStartOf="@id/cardDay"
            app:layout_constraintEnd_toEndOf="@id/cardDay"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>